package objetos;

import java.util.Scanner;

public class Main {

    public static void main(String[] args) {
        Scanner entrada = new Scanner(System.in);
      
        int bebida;
        String nomebebida ;
        boolean opcaoValida;
       
        do {
            System.out.println("Digite sua bebida, de 1 a 6:");
            System.out.println("1-Café");
            System.out.println("2-Machiato");
            System.out.println("3-Capuccino");
            System.out.println("4-Chocolate Quente");
            System.out.println("5-Café com leite");
            System.out.println("6-Chá Matte");
            
            bebida = entrada.nextInt();
            
           
            opcaoValida = true; 
           
            switch (bebida) {
                case 1: nomebebida = "Café"; break;
                case 2: nomebebida = "Machiato"; break;
                case 3: nomebebida = "Capuccino"; break;
                case 4: nomebebida = "Chocolate Quente"; break;
                case 5: nomebebida = "Café com leite"; break;
                case 6: nomebebida = "Chá Matte"; break;
                default: 
                    System.out.println("\nNúmero inválido! Tente novamente.\n");
                    nomebebida = "Número inválido"; 
                    opcaoValida = false; 
                    break;
            }
        	
        } while (!opcaoValida); 
    
     
        System.out.println("\nBebida selecionada: " + nomebebida);
        System.out.println("Fazendo " + nomebebida);
        System.out.println("Aguarde...");

        entrada.close();
    } 
} 
